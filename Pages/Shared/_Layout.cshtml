<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Order Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --clr-bg:       #0f0f1a;
            --clr-surface:  #1a1a2e;
            --clr-card:     #16213e;
            --clr-border:   #2a2a4a;
            --clr-violet:   #7c3aed;
            --clr-pink:     #ec4899;
            --clr-cyan:     #06b6d4;
            --clr-amber:    #f59e0b;
            --clr-green:    #10b981;
            --clr-text:     #e2e8f0;
            --clr-muted:    #94a3b8;
            --grad-main: linear-gradient(135deg, var(--clr-violet), var(--clr-pink));
            --grad-accent: linear-gradient(135deg, var(--clr-cyan), var(--clr-green));
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--clr-bg);
            color: var(--clr-text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse 80% 50% at 20% -10%, rgba(124,58,237,.25) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 110%, rgba(6,182,212,.15) 0%, transparent 60%);
        }

        /* ── NAV ── */
        header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(15,15,26,.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--clr-border);
        }
        .nav-inner {
            max-width: 1100px; margin: 0 auto;
            padding: .9rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        .brand {
            font-family: 'Syne', sans-serif;
            font-size: 1.35rem; font-weight: 800;
            background: var(--grad-main);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            text-decoration: none;
        }
        .nav-links { display: flex; align-items: center; gap: 1rem; }
        .nav-links a {
            color: var(--clr-muted); text-decoration: none;
            font-weight: 500; font-size: .9rem;
            transition: color .2s;
        }
        .nav-links a:hover { color: var(--clr-text); }
        .btn-new {
            background: var(--grad-main);
            color: #fff !important;
            padding: .45rem 1.1rem;
            border-radius: 999px;
            font-weight: 600; font-size: .85rem;
            text-decoration: none;
            transition: opacity .2s, transform .15s;
            box-shadow: 0 0 18px rgba(124,58,237,.4);
        }
        .btn-new:hover { opacity: .88; transform: translateY(-1px); }

        /* ── MAIN ── */
        main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; }

        /* ── CARDS ── */
        .glass-card {
            background: var(--clr-card);
            border: 1px solid var(--clr-border);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 8px 32px rgba(0,0,0,.4);
        }

        /* ── PAGE TITLE ── */
        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 2rem; font-weight: 800;
            background: var(--grad-main);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: .25rem;
        }
        .page-sub { color: var(--clr-muted); font-size: .9rem; margin-bottom: 1.75rem; }

        /* ── TABLE ── */
        .orders-table { width: 100%; border-collapse: separate; border-spacing: 0 .5rem; }
        .orders-table thead th {
            color: var(--clr-muted); font-size: .78rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: .06em;
            padding: .5rem 1rem; border-bottom: 1px solid var(--clr-border);
        }
        .orders-table tbody tr {
            background: var(--clr-surface);
            border-radius: 10px;
            transition: transform .15s, box-shadow .15s;
        }
        .orders-table tbody tr:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(124,58,237,.2);
        }
        .orders-table tbody td {
            padding: .85rem 1rem;
            font-size: .9rem;
            border-top: 1px solid var(--clr-border);
            border-bottom: 1px solid var(--clr-border);
        }
        .orders-table tbody td:first-child {
            border-left: 1px solid var(--clr-border);
            border-radius: 10px 0 0 10px;
        }
        .orders-table tbody td:last-child {
            border-right: 1px solid var(--clr-border);
            border-radius: 0 10px 10px 0;
        }
        .badge-id {
            background: rgba(124,58,237,.2);
            color: #a78bfa;
            padding: .2rem .6rem; border-radius: 999px;
            font-size: .78rem; font-weight: 700;
        }
        .price-tag { color: var(--clr-cyan); font-weight: 600; }
        .total-tag { color: var(--clr-green); font-weight: 700; }
        .date-tag  { color: var(--clr-muted); font-size: .85rem; }

        /* ── ACTION BUTTONS ── */
        .btn-edit, .btn-del {
            padding: .3rem .85rem; border-radius: 8px;
            font-size: .8rem; font-weight: 600;
            text-decoration: none; display: inline-block;
            transition: opacity .2s, transform .15s;
        }
        .btn-edit { background: rgba(6,182,212,.15); color: var(--clr-cyan); border: 1px solid rgba(6,182,212,.3); }
        .btn-del  { background: rgba(236,72,153,.15); color: var(--clr-pink); border: 1px solid rgba(236,72,153,.3); margin-left: .35rem; }
        .btn-edit:hover, .btn-del:hover { opacity: .8; transform: translateY(-1px); }

        /* ── FORM ── */
        .form-label { color: var(--clr-muted); font-size: .82rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .4rem; display: block; }
        .form-control {
            width: 100%;
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: 10px;
            color: var(--clr-text);
            padding: .65rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .form-control:focus {
            border-color: var(--clr-violet);
            box-shadow: 0 0 0 3px rgba(124,58,237,.2);
        }
        .input-prefix {
            display: flex; align-items: center;
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: 10px; overflow: hidden;
        }
        .input-prefix span {
            padding: .65rem .9rem;
            color: var(--clr-amber);
            font-weight: 700;
            border-right: 1px solid var(--clr-border);
        }
        .input-prefix .form-control { border: none; border-radius: 0; }
        .input-prefix .form-control:focus { box-shadow: none; }
        .mb-field { margin-bottom: 1.25rem; }
        .text-danger { color: #f87171 !important; font-size: .8rem; margin-top: .3rem; display: block; }

        /* ── SUBMIT BUTTONS ── */
        .btn-submit {
            background: var(--grad-main);
            color: #fff; border: none; cursor: pointer;
            padding: .7rem 1.8rem; border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .95rem;
            box-shadow: 0 0 20px rgba(124,58,237,.35);
            transition: opacity .2s, transform .15s;
        }
        .btn-submit:hover { opacity: .88; transform: translateY(-1px); }
        .btn-cancel {
            background: var(--clr-surface);
            color: var(--clr-muted); border: 1px solid var(--clr-border);
            padding: .7rem 1.4rem; border-radius: 10px;
            text-decoration: none; font-weight: 600; font-size: .95rem;
            transition: color .2s;
        }
        .btn-cancel:hover { color: var(--clr-text); }
        .btn-danger-solid {
            background: linear-gradient(135deg, #dc2626, var(--clr-pink));
            color: #fff; border: none; cursor: pointer;
            padding: .7rem 1.8rem; border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .95rem;
            box-shadow: 0 0 20px rgba(236,72,153,.3);
            transition: opacity .2s, transform .15s;
        }
        .btn-danger-solid:hover { opacity: .88; transform: translateY(-1px); }

        /* ── DETAIL LIST (delete page) ── */
        .detail-list { display: grid; grid-template-columns: 140px 1fr; gap: .6rem 1rem; }
        .detail-list dt { color: var(--clr-muted); font-size: .82rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; align-self: center; }
        .detail-list dd { color: var(--clr-text); font-weight: 500; }

        /* ── EMPTY STATE ── */
        .empty-state { text-align: center; padding: 3rem 1rem; color: var(--clr-muted); }
        .empty-state a { color: var(--clr-violet); }

        /* ── ALERT ── */
        .alert-warn {
            background: rgba(245,158,11,.1);
            border: 1px solid rgba(245,158,11,.3);
            color: var(--clr-amber);
            border-radius: 10px; padding: 1rem 1.25rem;
            margin-bottom: 1.5rem; font-size: .9rem;
        }

        /* ── FOOTER ── */
        footer {
            text-align: center; padding: 2rem;
            color: var(--clr-muted); font-size: .8rem;
            border-top: 1px solid var(--clr-border);
            margin-top: 4rem;
        }
    </style>
</head>
<body>
    <header>
        <div class="nav-inner">
            <a class="brand" asp-page="/Orders/Index">🛒 Order Manager</a>
            <div class="nav-links">
                <a asp-page="/Orders/Index">📋 View Records</a>
                <a class="btn-new" asp-page="/Orders/Create">➕ Add Record</a>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        ASPCRUDAssignment &copy; @DateTime.Now.Year
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
